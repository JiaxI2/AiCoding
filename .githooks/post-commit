#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
cd "$repo_root"

# Incrementally refresh repo-context and validation aliases after each commit.
# This is best-effort, never builds the CLI, and never blocks the commit.
if [ -x "bin/aicoding" ]; then
  bin/aicoding hook post-commit || true
  exit 0
fi

if [ -x "bin/aicoding.exe" ]; then
  bin/aicoding.exe hook post-commit || true
  exit 0
fi

exit 0
