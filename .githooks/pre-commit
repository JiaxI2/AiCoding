#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
cd "$repo_root"

if [ -x "bin/aicoding" ]; then
  exec bin/aicoding hook pre-commit
fi

if [ -x "bin/aicoding.exe" ]; then
  exec bin/aicoding.exe hook pre-commit
fi

if command -v go >/dev/null 2>&1 && [ -d "cmd/aicoding" ]; then
  exec go run ./cmd/aicoding hook pre-commit
fi

echo "AiCoding fast CLI or Go is required for pre-commit checks" >&2
exit 1
