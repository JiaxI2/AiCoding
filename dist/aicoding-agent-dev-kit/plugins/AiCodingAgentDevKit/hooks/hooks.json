{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File \"${PLUGIN_ROOT}/hooks/session-start.ps1\"",
            "timeout": 60,
            "statusMessage": "AiCoding Agent Dev Kit: loading minimal context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File \"${PLUGIN_ROOT}/hooks/user-prompt-submit.ps1\"",
            "timeout": 30,
            "statusMessage": "AiCoding Agent Dev Kit: checking context scope"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File \"${PLUGIN_ROOT}/hooks/stop.ps1\"",
            "timeout": 30,
            "statusMessage": "AiCoding Agent Dev Kit: showing context manifest"
          }
        ]
      }
    ]
  }
}
