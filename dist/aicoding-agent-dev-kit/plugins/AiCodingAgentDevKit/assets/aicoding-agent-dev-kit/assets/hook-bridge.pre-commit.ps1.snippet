# BEGIN AICODING_AGENT_DEV_KIT_BRIDGE
$repoRoot = git rev-parse --show-toplevel
$agentDevKitGate = Join-Path $repoRoot "scripts/invoke-agent-quality-gate.ps1"
if (Test-Path -LiteralPath $agentDevKitGate) {
    pwsh -NoProfile -ExecutionPolicy Bypass -File $agentDevKitGate -Mode pre-commit -Json
    if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }
}
# END AICODING_AGENT_DEV_KIT_BRIDGE
