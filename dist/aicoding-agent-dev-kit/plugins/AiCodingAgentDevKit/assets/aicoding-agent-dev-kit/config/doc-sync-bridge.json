{
  "schema": "aicoding-agent-dev-kit.docsync-bridge.v1",
  "version": "0.11.1",
  "enabledWhenScriptExists": "scripts/check-documentation-sync.ps1",
  "preCommitModes": [
    "pre-commit",
    "staged"
  ],
  "ciModes": [
    "ci",
    "all"
  ],
  "policy": "orchestrate-do-not-replace",
  "notes": [
    "Agent Dev Kit controls agent workflow efficiency.",
    "DocSync controls official documentation consistency.",
    "Quality gate should call DocSync if the target repository provides it."
  ]
}
