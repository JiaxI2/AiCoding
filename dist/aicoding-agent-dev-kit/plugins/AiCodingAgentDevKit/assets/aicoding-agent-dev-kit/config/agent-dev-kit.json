{
  "schema": "aicoding-agent-dev-kit.v1",
  "version": "0.11.1",
  "mode": "platform-kit",
  "desensitized": true,
  "thinSkill": true,
  "superpowers": {
    "required": false,
    "role": "optional-local-accelerator",
    "ciDependency": false
  },
  "install": {
    "statePath": ".agent-dev-kit/install-state.json",
    "safeUninstallPreserves": [
      "spec",
      ".agent-memory/DECISIONS.md",
      "docs/adr",
      "specs/bdd",
      "specs/tdd",
      "docs/traceability"
    ]
  },
  "qualityGate": {
    "singleEntrypoint": "scripts/invoke-agent-quality-gate.ps1",
    "modes": [
      "pre-commit",
      "ci",
      "all",
      "release"
    ],
    "requiredValidators": [
      "validate-spec-pack",
      "validate-implementation-plan",
      "validate-tdd",
      "validate-memory",
      "validate-adr",
      "validate-bdd",
      "validate-traceability",
      "validate-desensitization"
    ]
  },
  "memory": {
    "mode": "lightweight-decision-memory",
    "files": [
      ".agent-memory/CURRENT.md",
      ".agent-memory/DECISIONS.md"
    ],
    "fullMemorySystem": false
  },
  "loader": {
    "enabled": true,
    "policy": "config/loading-policy.json",
    "contextPack": ".agent-dev-kit/context/context-pack.md",
    "manifest": ".agent-dev-kit/context/context-manifest.json"
  },
  "codexNative": {
    "enabled": true,
    "plugin": "plugins/aicoding-agent-dev-kit/.codex-plugin/plugin.json",
    "marketplace": ".agents/plugins/marketplace.json",
    "projectHooks": ".codex/hooks.json",
    "projectAgents": ".codex/agents/*.toml",
    "trustRequired": true,
    "projectHooksDefaultInstall": false
  },
  "hookBridge": {
    "enabled": true,
    "policy": "orchestrate-do-not-own",
    "config": "config/hook-bridge.json",
    "defaultInstallGitHook": false,
    "overwriteExistingHook": false
  },
  "clarificationMode": {
    "enabled": true,
    "policy": "config/clarification-policy.json",
    "optionMatrix": "spec/PRD_OPTIONS.md",
    "selectedSolution": "spec/SELECTED_SOLUTION.md",
    "progressBoard": ".agent-dev-kit/progress/progress-board.json",
    "officialProgress": "spec/MVP_PROGRESS.md",
    "qualityGateValidator": "scripts/validate-solution-doc-sync.ps1"
  },
  "domainPolicy": {
    "applicationSpecificExamplesInKit": false,
    "applicationExamplesLocation": "target repository docs only"
  }
}
