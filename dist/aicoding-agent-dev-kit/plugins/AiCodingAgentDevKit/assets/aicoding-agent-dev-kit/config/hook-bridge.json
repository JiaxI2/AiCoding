{
  "schema": "aicoding-agent-dev-kit.hook-bridge.v1",
  "version": "0.11.1",
  "policy": "orchestrate-do-not-own",
  "gitHook": {
    "defaultInstall": false,
    "overwriteExisting": false,
    "preferredEntry": "existing repository hook",
    "bridgeMarkers": {
      "begin": "BEGIN AICODING_AGENT_DEV_KIT_BRIDGE",
      "end": "END AICODING_AGENT_DEV_KIT_BRIDGE"
    },
    "bridgeScript": "scripts/invoke-agent-quality-gate.ps1",
    "mode": "pre-commit"
  },
  "codexHook": {
    "defaultInstallProjectHooks": false,
    "trustRequired": true,
    "role": "optional lifecycle acceleration"
  },
  "enforcement": {
    "deterministic": [
      "existing Git hook",
      "CI quality gate"
    ],
    "optional": [
      "Codex lifecycle hooks"
    ]
  }
}
