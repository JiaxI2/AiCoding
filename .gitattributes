# AiCoding platform repository text normalization.
# User embedded projects may override this locally when GBK is an explicit project requirement.
* text=auto
.gitattributes text eol=lf
.gitmodules text eol=lf

*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.toml  text eol=lf
*.go    text eol=lf
*.tmpl  text eol=lf
*.svg   text eol=lf
*.sh    text eol=lf
.githooks/* text eol=lf

*.ps1   text eol=crlf
*.psm1  text eol=crlf
*.psd1  text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.zip   binary
*.exe   binary
*.dll   binary
*.out   binary
*.hex   text eol=crlf
