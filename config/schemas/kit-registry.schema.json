{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aicoding.local/schemas/kit-registry.schema.json",
  "title": "AiCoding Kit Registry",
  "type": "object",
  "required": [
    "schemaVersion",
    "name",
    "defaultMode",
    "kits"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "defaultMode": {
      "type": "string",
      "minLength": 1
    },
    "kits": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "enabled",
          "order",
          "manifest"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
          },
          "enabled": {
            "type": "boolean"
          },
          "order": {
            "type": "integer",
            "minimum": 0
          },
          "manifest": {
            "type": "string",
            "pattern": "^config/kits/[A-Za-z0-9_.-]+\\.json$"
          }
        }
      }
    }
  }
}
