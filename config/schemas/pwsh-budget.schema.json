{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JiaxI2/AiCoding/config/schemas/pwsh-budget.schema.json",
  "title": "AiCoding PowerShell Budget Ratchet",
  "type": "object",
  "required": ["schemaVersion", "scope", "baselines"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "scope": { "type": "string", "const": "tools/specialty/*.ps1" },
    "baselines": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/baseline" }
    }
  },
  "$defs": {
    "baseline": {
      "type": "object",
      "required": ["remainingScripts", "unspecified", "scripts", "observedCommit", "evidence"],
      "additionalProperties": false,
      "properties": {
        "remainingScripts": { "type": "integer", "minimum": 0 },
        "unspecified": { "type": "integer", "const": 0 },
        "scripts": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^tools/specialty/[^/]+\\.ps1$" }
        },
        "observedCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "evidence": { "type": "string", "pattern": "^docs/operations/evidence/.+\\.json$" }
      }
    }
  }
}
