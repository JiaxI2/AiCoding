{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicoding.local/schemas/plan-spec.schema.json",
  "title": "AiCoding Plan Spec Frontmatter",
  "type": "object",
  "required": ["id", "status", "scope", "approvedTree", "gates"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "status": {
      "enum": ["draft", "needs-decision", "approved", "implemented", "archived"]
    },
    "scope": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "approvedTree": {
      "type": "string"
    },
    "decision": {
      "type": "string"
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["profile"],
        "additionalProperties": false,
        "properties": {
          "profile": { "enum": ["smoke", "full", "release"] }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": { "enum": ["approved", "implemented"] }
        },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "approvedTree": { "pattern": "^(?:[0-9a-fA-F]{40}|[0-9a-fA-F]{64})$" }
        }
      }
    }
  ]
}
