{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loop-engineering.local/schemas/loop-attempt.schema.json",
  "title": "Loop Engineering Attempt",
  "type": "object",
  "additionalProperties": false,
  "required": ["number", "subjectTreeOID", "tokenUsage", "gateRefs", "startedAt", "endedAt"],
  "properties": {
    "number": {"type": "integer", "minimum": 1},
    "subjectTreeOID": {"type": "string", "minLength": 1},
    "tokenUsage": {
      "type": "object",
      "required": ["input_tokens", "cached_input_tokens", "cache_write_input_tokens", "output_tokens", "reasoning_output_tokens", "total_tokens", "updated_at"],
      "properties": {
        "source": {"type": "string"},
        "thread_id": {"type": "string"},
        "turn_id": {"type": "string"},
        "input_tokens": {"type": "integer", "minimum": 0},
        "cached_input_tokens": {"type": "integer", "minimum": 0},
        "cache_write_input_tokens": {"type": "integer", "minimum": 0},
        "output_tokens": {"type": "integer", "minimum": 0},
        "reasoning_output_tokens": {"type": "integer", "minimum": 0},
        "total_tokens": {"type": "integer", "minimum": 0},
        "context_tokens": {"type": "integer", "minimum": 0},
        "context_window": {"type": "integer", "minimum": 0},
        "context_remaining": {"type": "integer", "minimum": 0},
        "context_used_percent": {"type": "number", "minimum": 0, "maximum": 100},
        "updated_at": {"type": "string", "format": "date-time"}
      }
    },
    "gateRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["profile", "validationIdentity", "receiptID"],
        "properties": {
          "profile": {"type": "string", "minLength": 1},
          "validationIdentity": {"type": "string", "minLength": 1},
          "receiptID": {"type": "string", "minLength": 1}
        }
      }
    },
    "startedAt": {"type": "string", "format": "date-time"},
    "endedAt": {"type": "string", "format": "date-time"}
  }
}
