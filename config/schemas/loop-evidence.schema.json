{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicoding.local/schemas/loop-evidence.schema.json",
  "title": "AiCoding Loop Evidence Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "workDigest", "attempt", "sourceState", "checks", "conclusion"],
  "properties": {
    "schemaVersion": {"const": 1},
    "workDigest": {"type": "string", "pattern": "^sha256:"},
    "attempt": {"type": "integer", "minimum": 1},
    "sourceState": {
      "type": "object",
      "required": ["head", "dirty"],
      "properties": {
        "head": {"type": "string"},
        "dirty": {"type": "boolean"}
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "status"],
        "properties": {
          "id": {"type": "string"},
          "status": {"enum": ["PASS", "WARN", "FAIL", "SKIP"]},
          "evidenceRef": {"type": "string"}
        }
      }
    },
    "conclusion": {"enum": ["VERIFIED", "CONTINUE", "BLOCKED", "NEEDS_HUMAN", "EXHAUSTED"]}
  }
}
