{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicoding.local/schemas/c99-standard-c-skill.schema.json",
  "title": "AiCoding C99 Standard C Skill Configuration",
  "type": "object",
  "required": ["schemaVersion", "id", "title", "language", "standard", "formatter", "commentTemplates", "rules", "kit", "excludedDirectories"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "const": "c99-standard-c" },
    "title": { "type": "string", "minLength": 1 },
    "language": { "const": "c" },
    "standard": { "const": "c99" },
    "formatter": {
      "type": "object",
      "required": ["id", "config"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "config": { "type": "string", "minLength": 1 }
      }
    },
    "commentTemplates": { "type": "string", "minLength": 1 },
    "rules": { "type": "string", "minLength": 1 },
    "kit": {
      "type": "object",
      "required": ["id", "version", "root", "config", "snippets", "quickTarget"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "root": { "type": "string", "minLength": 1 },
        "config": { "type": "string", "minLength": 1 },
        "snippets": { "type": "string", "minLength": 1 },
        "quickTarget": { "type": "string", "minLength": 1 }
      }
    },
    "excludedDirectories": { "type": "array", "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
  }
}
