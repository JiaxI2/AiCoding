{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JiaxI2/AiCoding/config/schemas/asset.schema.json",
  "title": "AiCoding Universal Asset Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "type", "version"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "type": { "enum": ["kit", "skill", "mcp", "template", "ruleset", "profile"] },
    "version": { "type": "string", "minLength": 1 },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "mode": { "enum": ["managed", "editable"] },
    "payload": { "type": "string" },
    "platforms": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "capabilities": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "optional": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "defaults": { "type": "string" },
        "schema": { "type": "string" }
      }
    },
    "metadata": { "type": "object" }
  }
}
