{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicoding.local/schemas/tagging-policy.schema.json",
  "title": "AiCoding Tagging Policy",
  "type": "object",
  "required": ["schemaVersion", "name", "platformTagPattern", "kitTagPattern", "milestoneTagPattern", "nonCurrentDateTagPattern", "rules"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "name": { "type": "string", "minLength": 1 },
    "platformTagPattern": { "type": "string", "minLength": 1 },
    "kitTagPattern": { "type": "string", "minLength": 1 },
    "milestoneTagPattern": { "type": "string", "minLength": 1 },
    "nonCurrentDateTagPattern": { "type": "string", "minLength": 1 },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
