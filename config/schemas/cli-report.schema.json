{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JiaxI2/AiCoding/config/schemas/cli-report.schema.json",
  "title": "AiCoding CLI Report",
  "type": "object",
  "required": [
    "schemaVersion",
    "command",
    "ok",
    "category",
    "retryable",
    "elapsedMs"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "ok": {
      "type": "boolean"
    },
    "errorKind": {
      "type": "string",
      "enum": [
        "usage",
        "execution",
        "validation"
      ]
    },
    "category": {
      "type": "string",
      "enum": [
        "none",
        "usage",
        "validation",
        "transient",
        "toolchain",
        "evidence-missing",
        "conflict",
        "internal"
      ]
    },
    "retryable": {
      "type": "boolean"
    },
    "nextAction": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": "string"
    },
    "repoRoot": {
      "type": "string"
    },
    "inputDigest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "planDigest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "checked": true,
    "data": true,
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "elapsedMs": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false,
  "$defs": {
    "finding": {
      "type": "object",
      "required": [
        "level",
        "message"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "WARN",
            "ERROR",
            "FAIL"
          ]
        },
        "message": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "log": {
      "type": "object",
      "required": [
        "label",
        "path"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "check": {
      "type": "object",
      "required": [
        "id",
        "category",
        "ok",
        "status",
        "duration_ms"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "ok": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "PASS_WITH_WARNINGS",
            "FAIL"
          ]
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "details": true
      },
      "additionalProperties": false
    },
    "standardReport": {
      "type": "object",
      "required": [
        "schemaVersion",
        "status",
        "summary",
        "findings",
        "command",
        "profile",
        "duration_ms",
        "logs"
      ],
      "properties": {
        "schemaVersion": {
          "type": "integer",
          "const": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "PASS_WITH_WARNINGS",
            "FAIL"
          ]
        },
        "summary": {
          "type": "object"
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "command": {
          "type": "string"
        },
        "profile": {
          "type": "string"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "logs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/log"
          }
        },
        "details": true
      },
      "additionalProperties": false
    }
  }
}
