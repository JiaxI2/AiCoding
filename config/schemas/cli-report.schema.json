{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JiaxI2/AiCoding/config/schemas/cli-report.schema.json",
  "title": "AiCoding CLI Report",
  "type": "object",
  "required": [
    "schemaVersion",
    "command",
    "ok",
    "category",
    "retryable",
    "elapsedMs"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "ok": {
      "type": "boolean"
    },
    "errorKind": {
      "type": "string",
      "enum": [
        "usage",
        "execution",
        "validation"
      ]
    },
    "category": {
      "type": "string",
      "enum": [
        "none",
        "usage",
        "validation",
        "transient",
        "toolchain",
        "evidence-missing",
        "conflict",
        "internal"
      ]
    },
    "retryable": {
      "type": "boolean"
    },
    "nextAction": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": "string"
    },
    "repoRoot": {
      "type": "string"
    },
    "inputDigest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "planDigest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "checked": true,
    "data": true,
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "elapsedMs": {
      "type": "integer",
      "minimum": 0
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "command": { "const": "doctor pwsh" }
        },
        "required": ["command"]
      },
      "then": {
        "required": ["data"],
        "properties": {
          "data": { "$ref": "#/$defs/pwshInventory" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "command": { "const": "doctor pwsh-budget" }
        },
        "required": ["command"]
      },
      "then": {
        "required": ["data"],
        "properties": {
          "data": { "$ref": "#/$defs/pwshBudget" }
        }
      }
    }
  ],
  "additionalProperties": false,
  "$defs": {
    "pwshInventory": {
      "type": "object",
      "required": ["calls", "retirement"],
      "properties": {
        "calls": {
          "type": "array",
          "items": { "$ref": "#/$defs/pwshCall" }
        },
        "retirement": { "$ref": "#/$defs/pwshRetirement" }
      },
      "additionalProperties": false
    },
    "pwshCall": {
      "type": "object",
      "required": ["path", "line", "text", "category", "recommendation"],
      "properties": {
        "path": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "text": { "type": "string" },
        "category": { "type": "string" },
        "recommendation": { "type": "string" },
        "suggestedReplacement": { "type": "string" }
      },
      "additionalProperties": false
    },
    "pwshRetirement": {
      "type": "object",
      "required": ["scope", "remainingScripts", "thinShells", "deprecated", "unspecified", "scripts"],
      "properties": {
        "scope": { "type": "string", "const": "tools/specialty/*.ps1" },
        "remainingScripts": { "type": "integer", "minimum": 0 },
        "thinShells": { "type": "integer", "minimum": 0 },
        "deprecated": { "type": "integer", "minimum": 0 },
        "unspecified": { "type": "integer", "minimum": 0 },
        "scripts": {
          "type": "array",
          "items": { "$ref": "#/$defs/pwshRetirementScript" }
        }
      },
      "additionalProperties": false
    },
    "pwshRetirementScript": {
      "type": "object",
      "required": ["path", "thinShell", "deprecated", "retirementTrigger"],
      "properties": {
        "path": { "type": "string", "pattern": "^tools/specialty/.+\\.ps1$" },
        "thinShell": { "type": "boolean" },
        "deprecated": { "type": "boolean" },
        "retirementTrigger": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "pwshBudget": {
      "type": "object",
      "required": ["calls", "counts", "ratchet"],
      "properties": {
        "calls": {
          "type": "array",
          "items": { "$ref": "#/$defs/pwshBudgetCall" }
        },
        "counts": {
          "type": "object",
          "required": ["hot-path", "slow-path", "fallback", "documentation-only"],
          "properties": {
            "hot-path": { "type": "integer", "minimum": 0 },
            "slow-path": { "type": "integer", "minimum": 0 },
            "fallback": { "type": "integer", "minimum": 0 },
            "documentation-only": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "ratchet": { "$ref": "#/$defs/pwshBudgetRatchet" }
      },
      "additionalProperties": false
    },
    "pwshBudgetCall": {
      "type": "object",
      "required": ["path", "line", "text", "category", "budget", "recommendation"],
      "properties": {
        "path": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "text": { "type": "string" },
        "category": { "type": "string" },
        "budget": { "type": "string", "enum": ["hot-path", "slow-path", "fallback", "documentation-only"] },
        "recommendation": { "type": "string" },
        "suggestedReplacement": { "type": "string" }
      },
      "additionalProperties": false
    },
    "pwshBudgetRatchet": {
      "type": "object",
      "required": [
        "ok", "configPath", "scope", "baselineRemainingScripts", "currentRemainingScripts",
        "baselineUnspecified", "currentUnspecified", "baselineCommit", "evidence",
        "unexpectedScripts", "missingScripts"
      ],
      "properties": {
        "ok": { "type": "boolean" },
        "configPath": { "type": "string", "const": "config/pwsh-budget.json" },
        "scope": { "type": "string", "const": "tools/specialty/*.ps1" },
        "baselineRemainingScripts": { "type": "integer", "minimum": 0 },
        "currentRemainingScripts": { "type": "integer", "minimum": 0 },
        "baselineUnspecified": { "type": "integer", "const": 0 },
        "currentUnspecified": { "type": "integer", "minimum": 0 },
        "baselineCommit": { "type": "string", "pattern": "^(?:[0-9a-f]{40})?$" },
        "evidence": { "type": "string" },
        "unexpectedScripts": { "type": "array", "items": { "type": "string" } },
        "missingScripts": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "finding": {
      "type": "object",
      "required": [
        "level",
        "message"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "WARN",
            "ERROR",
            "FAIL"
          ]
        },
        "message": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "id": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "log": {
      "type": "object",
      "required": [
        "label",
        "path"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "check": {
      "type": "object",
      "required": [
        "id",
        "category",
        "ok",
        "status",
        "duration_ms"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "minLength": 1
        },
        "ok": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "PASS_WITH_WARNINGS",
            "FAIL"
          ]
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "details": true
      },
      "additionalProperties": false
    },
    "standardReport": {
      "type": "object",
      "required": [
        "schemaVersion",
        "status",
        "summary",
        "findings",
        "command",
        "profile",
        "duration_ms",
        "logs"
      ],
      "properties": {
        "schemaVersion": {
          "type": "integer",
          "const": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "PASS_WITH_WARNINGS",
            "FAIL"
          ]
        },
        "summary": {
          "type": "object"
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/finding"
          }
        },
        "command": {
          "type": "string"
        },
        "profile": {
          "type": "string"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "logs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/log"
          }
        },
        "details": true
      },
      "additionalProperties": false
    }
  }
}
