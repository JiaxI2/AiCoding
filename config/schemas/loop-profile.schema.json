{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loop-engineering.local/schemas/loop-profile.schema.json",
  "title": "Loop Engineering Profile",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "domain", "allowedTriggers", "requiredGates", "advisoryGates", "defaultCheckpoints"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "domain": {"enum": ["project-development", "repository-maintenance", "ci-repair", "performance-experiment", "documentation-maintenance", "architecture-evolution"]},
    "allowedTriggers": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["explicit", "scheduled", "agent-proposed"]}},
    "requiredGates": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "advisoryGates": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "defaultCheckpoints": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
  }
}
