{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicoding.local/schemas/impact-policy.schema.json",
  "title": "AiCoding Change Impact Policy",
  "type": "object",
  "required": ["schemaVersion", "raceScope", "changeVerify"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "raceScope": {
      "type": "object",
      "required": ["packages", "reason"],
      "additionalProperties": false,
      "properties": {
        "packages": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "changeVerify": {
      "type": "object",
      "required": ["defaultProfile", "rules"],
      "additionalProperties": false,
      "properties": {
        "defaultProfile": { "type": "string", "minLength": 1 },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/changeRule" }
        }
      }
    }
  },
  "$defs": {
    "changeRule": {
      "type": "object",
      "required": ["pattern", "profile", "reason"],
      "additionalProperties": false,
      "properties": {
        "pattern": { "$ref": "#/$defs/pathPattern" },
        "profile": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      }
    },
    "pathPattern": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^/\\\\][^\\\\]*$"
    }
  }
}
