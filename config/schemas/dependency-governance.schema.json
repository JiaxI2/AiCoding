{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicoding.local/schemas/dependency-governance.schema.json",
  "title": "AiCoding Dependency Direction Governance",
  "type": "object",
  "required": [
    "schemaVersion",
    "name",
    "direction",
    "layers",
    "reservedNamespaces",
    "scan",
    "versionVisibility",
    "kitRegistry",
    "mcpRegistry",
    "skills",
    "externalDependencies",
    "goPackageBoundaries"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "direction": {
      "const": "higher-rank-may-depend-on-equal-or-lower-rank"
    },
    "layers": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/layer"
      }
    },
    "reservedNamespaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/reservedNamespace"
      }
    },
    "scan": {
      "$ref": "#/$defs/scan"
    },
    "versionVisibility": {
      "$ref": "#/$defs/versionVisibility"
    },
    "kitRegistry": {
      "$ref": "#/$defs/registry"
    },
    "mcpRegistry": {
      "allOf": [
        {
          "$ref": "#/$defs/registry"
        },
        {
          "type": "object",
          "required": [
            "idPattern",
            "promptPolicy"
          ],
          "properties": {
            "idPattern": {
              "type": "string",
              "minLength": 1
            },
            "promptPolicy": {
              "const": "forbid-workflow-prompts"
            }
          }
        }
      ]
    },
    "skills": {
      "type": "object",
      "required": [
        "runtimeConfig",
        "pluginRoot",
        "pluginLayer",
        "pluginRequiredPrefix",
        "standaloneLayer",
        "standaloneForbiddenPrefixes"
      ],
      "additionalProperties": false,
      "properties": {
        "runtimeConfig": {
          "type": "string",
          "minLength": 1
        },
        "pluginRoot": {
          "type": "string",
          "minLength": 1
        },
        "pluginLayer": {
          "type": "string",
          "minLength": 1
        },
        "pluginRequiredPrefix": {
          "type": "string",
          "minLength": 1
        },
        "standaloneLayer": {
          "type": "string",
          "minLength": 1
        },
        "standaloneForbiddenPrefixes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "externalDependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "layer"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "layer": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "goPackageBoundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/goPackageBoundary"
      }
    }
  },
  "$defs": {
    "goPackageBoundary": {
      "type": "object",
      "required": [
        "path",
        "forbiddenImports"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^internal/[a-z0-9][a-z0-9/-]*$"
        },
        "forbiddenImports": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^internal/[a-z0-9][a-z0-9/-]*$"
          }
        }
      }
    },
    "layer": {
      "type": "object",
      "required": [
        "id",
        "rank",
        "description"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "rank": {
          "type": "integer",
          "minimum": 0
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "reservedNamespace": {
      "type": "object",
      "required": [
        "value",
        "ownerLayer"
      ],
      "additionalProperties": false,
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1
        },
        "ownerLayer": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "scan": {
      "type": "object",
      "required": [
        "extensions",
        "fileNames",
        "excludeDirectories"
      ],
      "additionalProperties": false,
      "properties": {
        "extensions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\."
          }
        },
        "fileNames": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "excludeDirectories": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "versionVisibility": {
      "type": "object",
      "required": [
        "identityPattern",
        "codeSelfVersionPattern",
        "codeSelfVersionAllowedSymbols",
        "readmeBodyVersionPattern",
        "codeExtensions",
        "codeFileNames",
        "documentationDirectories",
        "authorityFiles",
        "readmeFiles",
        "readmeBadges"
      ],
      "additionalProperties": false,
      "properties": {
        "identityPattern": {
          "type": "string",
          "minLength": 1
        },
        "codeSelfVersionPattern": {
          "type": "string",
          "minLength": 1
        },
        "codeSelfVersionAllowedSymbols": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "readmeBodyVersionPattern": {
          "type": "string",
          "minLength": 1
        },
        "codeExtensions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^\\."
          }
        },
        "codeFileNames": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "documentationDirectories": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "authorityFiles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "readmeFiles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "readmeBadges": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/versionBadge"
          }
        }
      }
    },
    "versionBadge": {
      "type": "object",
      "required": [
        "label",
        "imageFragment",
        "target",
        "authority",
        "displayVersion"
      ],
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "imageFragment": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "authority": {
          "enum": [
            "repository-release",
            "upstream-version",
            "upstream-project",
            "local-kit"
          ]
        },
        "displayVersion": {
          "type": "string"
        },
        "manifest": {
          "type": "string"
        }
      }
    },
    "registry": {
      "type": "object",
      "required": [
        "path",
        "bindings"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "idPattern": {
          "type": "string"
        },
        "promptPolicy": {
          "type": "string"
        },
        "bindings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/binding"
          }
        }
      }
    },
    "binding": {
      "type": "object",
      "required": [
        "id",
        "layer",
        "platformAgnostic",
        "roots",
        "dependsOn"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
        },
        "layer": {
          "type": "string",
          "minLength": 1
        },
        "platformAgnostic": {
          "type": "boolean"
        },
        "roots": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "exception": {
          "type": "object",
          "required": [
            "reason",
            "owner",
            "reviewBy"
          ],
          "additionalProperties": false,
          "properties": {
            "reason": {
              "type": "string",
              "minLength": 1
            },
            "owner": {
              "type": "string",
              "minLength": 1
            },
            "reviewBy": {
              "type": "string",
              "format": "date"
            }
          }
        }
      }
    }
  }
}
