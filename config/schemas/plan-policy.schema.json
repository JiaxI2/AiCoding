{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicoding.local/schemas/plan-policy.schema.json",
  "title": "AiCoding Plan Trigger Policy",
  "type": "object",
  "required": ["schemaVersion", "sensitivePaths", "exemptPaths"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "sensitivePaths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sensitivePath"
      }
    },
    "exemptPaths": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/pathPattern"
      }
    }
  },
  "$defs": {
    "pathPattern": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^/\\\\][^\\\\]*$"
    },
    "sensitivePath": {
      "type": "object",
      "required": ["pattern", "reason"],
      "additionalProperties": false,
      "properties": {
        "pattern": {
          "$ref": "#/$defs/pathPattern"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
