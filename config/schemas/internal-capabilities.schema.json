{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicoding.local/schemas/internal-capabilities.schema.json",
  "title": "AiCoding Internal Capabilities",
  "type": "object",
  "required": ["schemaVersion", "name", "capabilities"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "name": { "type": "string", "minLength": 1 },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/capability" }
    }
  },
  "$defs": {
    "capability": {
      "type": "object",
      "required": ["id", "package", "name", "type", "status", "summary", "publicEntries"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
        "package": { "type": "string", "pattern": "^internal/[a-z0-9]+$" },
        "name": { "type": "string", "minLength": 1 },
        "type": { "enum": ["primitive", "domain-capability", "product-workflow", "internal-only"] },
        "status": { "enum": ["experimental", "beta", "stable", "deprecated"] },
        "summary": { "type": "string", "minLength": 1 },
        "publicEntries": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^aicoding(?: |$)" }
        },
        "architectureDoc": { "type": "string", "minLength": 1 },
        "verification": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "publicEntries": { "minItems": 1 } } },
          "then": { "required": ["architectureDoc"] }
        },
        {
          "if": { "properties": { "status": { "const": "stable" } } },
          "then": { "required": ["verification"] }
        }
      ]
    }
  }
}
