{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aicoding.local/schemas/schema-closure-exclusions.schema.json",
  "title": "AiCoding Config Schema Closure Exclusions",
  "type": "object",
  "required": ["schemaVersion", "exclusions"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "exclusions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": ["path", "reason"],
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
