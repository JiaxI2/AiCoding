{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aicoding.local/schemas/kit-manifest.schema.json",
  "title": "AiCoding Kit Manifest",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "name",
    "version",
    "kind",
    "mode",
    "commands"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "integer", "enum": [2] },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "kind": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "mode": { "type": "string", "enum": ["go-builtin", "external-cli", "powershell-specialty", "declarative"] },
    "description": { "type": "string" },
    "paths": { "type": "object", "additionalProperties": { "type": "string" } },
    "commands": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["type"],
        "additionalProperties": false,
        "properties": {
          "type": { "type": "string", "enum": ["builtin-check", "builtin-lifecycle", "builtin-package", "external-command", "go-composed", "specialty-pwsh", "unsupported"] },
          "path": { "type": "string", "minLength": 1 },
          "args": { "type": "array", "items": { "type": "string" } },
          "extraArgs": { "type": "array", "items": { "type": "string" } },
          "supportsJson": { "type": "boolean" },
          "supportsDryRun": { "type": "boolean" },
          "executable": { "type": "string", "minLength": 1 },
          "steps": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "requiredPaths": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "include": { "type": "array", "items": { "type": "string", "minLength": 1 } },
          "exclude": { "type": "array", "items": { "type": "string" } },
          "outputName": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "skills": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "umbrella": { "$ref": "#/definitions/skill" },
        "members": { "type": "array", "items": { "$ref": "#/definitions/skill" } }
      }
    },
    "hooks": {
      "type": "object",
      "additionalProperties": true
    },
    "commonDependencies": {
      "type": "array",
      "items": { "$ref": "#/definitions/commonDependency" }
    },
    "export": {
      "type": "object",
      "additionalProperties": true
    },
    "state": {
      "type": "object",
      "additionalProperties": true
    },
    "trust": {
      "type": "object",
      "additionalProperties": true
    },
    "profiles": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "definitions": {
    "skill": {
      "type": "object",
      "required": ["id", "path", "role"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "commonDependency": {
      "type": "object",
      "required": ["id", "path"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "version": { "type": "string" },
        "usage": { "type": "string" }
      }
    }
  }
}