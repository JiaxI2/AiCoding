{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AiCoding Agent Dev Kit Plan Mode Registry",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "owner",
    "phases",
    "stopFiles",
    "acceptedDecisionArtifacts",
    "architectureSensitivePaths",
    "requiredMarkers",
    "hookModules"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer"
    },
    "id": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "artifact",
          "requiredWhen"
        ],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "artifact": { "type": "string", "minLength": 1 },
          "requiredWhen": { "type": "string", "minLength": 1 }
        }
      }
    },
    "stopFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptedDecisionArtifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "architectureSensitivePaths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requiredMarkers": {
      "type": "object",
      "required": [
        "selectedDecision",
        "approvedPlan"
      ],
      "additionalProperties": false,
      "properties": {
        "selectedDecision": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "approvedPlan": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "hookModules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "languagePolicy": {
      "$comment": "Language policy additions are consumed by the external Plan Mode kit and remain an intentional extension point.",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "defaultUserLanguage": {
          "type": "string"
        },
        "userFacingOutput": {
          "type": "string"
        },
        "permissionSummary": {
          "type": "string"
        },
        "toolExplanation": {
          "type": "string"
        },
        "hookMessage": {
          "type": "string"
        },
        "scriptMessage": {
          "type": "string"
        },
        "allowEnglishTerms": {
          "type": "boolean"
        },
        "preserveMachineKeys": {
          "type": "boolean"
        },
        "examples": {
          "$comment": "Example names are documentation keys owned by the Plan Mode kit.",
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
