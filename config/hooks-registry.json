{
  "schemaVersion": 1,
  "hooks": [
    {
      "id": "docsync-pre-commit",
      "owner": "docsync-plus",
      "type": "repo-hook",
      "trigger": "pre-commit",
      "path": "bin/aicoding.exe docsync staged --json",
      "enabledByDefault": true,
      "machineReadable": true
    },
    {
      "id": "validation-pre-push",
      "owner": "aicoding-platform",
      "type": "repo-hook",
      "trigger": "pre-push",
      "path": "bin/aicoding.exe hook pre-push --json",
      "enabledByDefault": true,
      "machineReadable": true,
      "description": "按实际 local_oid tree 检查受治理 ref 的 Validation Receipt，不在 hook 内运行测试或构建。"
    },
    {
      "id": "plan-mode-gate",
      "owner": "aicoding-agent-dev-kit",
      "type": "agent-hook",
      "trigger": "pre-implementation",
      "path": "tools/specialty/hooks/aef/plan-mode-gate.ps1",
      "enabledByDefault": true,
      "machineReadable": true,
      "mode": "enforce",
      "description": "当 Plan Mode 决策或计划产物缺失时，阻止架构敏感实现继续执行。"
    },
    {
      "id": "spec-artifact-gate",
      "owner": "aicoding-agent-dev-kit",
      "type": "agent-hook",
      "trigger": "post-tool-use",
      "path": "tools/specialty/hooks/aef/spec-artifact-gate.ps1",
      "enabledByDefault": true,
      "machineReadable": true,
      "mode": "warn",
      "description": "当实现敏感变更缺少计划、任务或可追溯性文档时发出门禁提示。"
    }
  ]
}
