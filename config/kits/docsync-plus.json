{
  "schemaVersion": 2,
  "id": "docsync-plus",
  "name": "DocSync Plus",
  "version": "0.1.0",
  "kind": [
    "repo-hook-kit",
    "docsync-kit",
    "governance-kit"
  ],
  "mode": "declarative",
  "description": "Semantic documentation drift detection kit for AiCoding repositories.",
  "paths": {
    "entrypoint": "bin/aicoding.exe docsync",
    "moduleRoot": "internal/docsync",
    "policy": "config/docs-sync.policy.json",
    "semanticPolicy": "config/docs-sync.semantic.json",
    "stateRoot": ".aicoding/state/kits/docsync-plus"
  },
  "commands": {
    "install": {
      "type": "builtin-lifecycle",
      "requiredPaths": [
        "internal/docsync/docsync.go",
        "internal/docsync/check.go",
        "config/docs-sync.policy.json",
        "config/docs-sync.semantic.json"
      ],
      "supportsJson": true,
      "supportsDryRun": true
    },
    "status": {
      "type": "builtin-check",
      "requiredPaths": [
        "internal/docsync/docsync.go",
        "internal/docsync/check.go",
        "config/docs-sync.policy.json",
        "config/docs-sync.semantic.json"
      ]
    },
    "verify": {
      "type": "builtin-check",
      "requiredPaths": [
        "internal/docsync/docsync.go",
        "internal/docsync/check.go",
        "config/docs-sync.policy.json",
        "config/docs-sync.semantic.json",
        ".github/workflows/docs-sync.yml"
      ]
    },
    "test": {
      "type": "builtin-check",
      "requiredPaths": [
        "internal/docsync/classifier_test.go",
        "internal/docsync/check.go"
      ]
    },
    "uninstall": {
      "type": "unsupported",
      "reason": "DocSync Plus is integrated as repository governance files. Safe uninstall requires state-based ownership first."
    },
    "update": {
      "type": "builtin-lifecycle",
      "requiredPaths": [
        "internal/docsync/docsync.go",
        "internal/docsync/check.go",
        "config/docs-sync.policy.json",
        "config/docs-sync.semantic.json"
      ],
      "supportsJson": true,
      "supportsDryRun": true
    },
    "export": {
      "type": "builtin-package",
      "include": [
        "internal/docsync/**",
        "config/docs-sync.policy.json",
        "config/docs-sync.semantic.json",
        "docs/DOC_SYNC_PLUS_SPEC.md",
        "docs/DOC_SYNC_PLUS_VALIDATION_PLAN.md",
        ".github/workflows/docs-sync.yml"
      ],
      "exclude": [],
      "outputName": "docsync-plus-${version}.zip"
    }
  },
  "skills": {
    "members": []
  },
  "hooks": {
    "repo": [
      {
        "id": "docsync-pre-commit",
        "type": "pre-commit",
        "path": "bin/aicoding.exe docsync staged --json",
        "enabledByDefault": true,
        "owner": "docsync-plus"
      }
    ],
    "agent": []
  },
  "commonDependencies": [],
  "export": {
    "include": [
      "internal/docsync/**",
      "config/docs-sync.policy.json",
      "config/docs-sync.semantic.json",
      "docs/DOC_SYNC_PLUS_SPEC.md",
      "docs/DOC_SYNC_PLUS_VALIDATION_PLAN.md",
      ".github/workflows/docs-sync.yml"
    ],
    "exclude": [],
    "outputName": "docsync-plus-${version}.zip"
  },
  "state": {
    "root": ".aicoding/state/kits/docsync-plus",
    "installState": ".aicoding/state/kits/docsync-plus/install-state.json"
  },
  "trust": {
    "level": "first-party",
    "source": "AiCoding",
    "thirdParty": false,
    "updatePolicy": "manual"
  },
  "profiles": {
    "Smoke": {
      "default": true,
      "maxSeconds": 20
    },
    "Full": {
      "explicit": true
    },
    "Release": {
      "explicit": true,
      "packageRestore": true
    }
  }
}
