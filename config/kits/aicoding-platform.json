{
  "schemaVersion": 2,
  "id": "aicoding-platform",
  "name": "AiCoding Platform",
  "version": "0.1.0",
  "kind": [
    "platform-kit",
    "plugin-kit"
  ],
  "mode": "go-builtin",
  "description": "AiCoding platform integration, Codex plugin marketplace registration, CodingKit asset discovery, and submodule validation.",
  "paths": {
    "config": "config/codex-kit.json",
    "pluginRoot": "CodingKit/agents/skills/plugins/AiCoding",
    "marketplace": ".agents/plugins/marketplace.json",
    "submodule": "CodingKit/agents/skills"
  },
  "commands": {
    "install": {
      "type": "builtin-lifecycle",
      "requiredPaths": [
        "CodingKit/agents/skills/plugins/AiCoding",
        "CodingKit/agents/skills/plugins/AiCoding/.codex-plugin/plugin.json",
        "CodingKit/agents/skills/plugins/AiCoding/BUILDINFO.json",
        "config/codex-kit.json",
        ".agents/plugins/marketplace.json"
      ],
      "supportsJson": true,
      "supportsDryRun": true
    },
    "status": {
      "type": "external-command",
      "executable": "bin/aicoding.exe",
      "args": [
        "lifecycle",
        "status",
        "--scope",
        "kit",
        "--all",
        "--json"
      ],
      "supportsJson": true
    },
    "verify": {
      "type": "builtin-check",
      "requiredPaths": [
        "config/codex-kit.json",
        "config/kit-registry.json",
        "config/dependency-governance.json",
        "config/schemas/dependency-governance.schema.json",
        "config/mcp-registry.json",
        "config/mcp/components/visio-mcp.json",
        "config/mcp/components/ppt-mcp.json",
        "config/schemas/mcp-registry.schema.json",
        "config/schemas/mcp-component.schema.json",
        "CodingKit/agents/skills/visio-diagram/SKILL.md",
        "internal/kit/structure.go",
        "internal/governance/dependencies.go",
        "internal/mcpcontrol/registry.go",
        "internal/mcpcontrol/probe.go",
        "internal/cli/cli_mcp.go",
        "internal/cli/cli.go"
      ],
      "supportsJson": true
    },
    "test": {
      "type": "go-composed",
      "steps": [
        "verify"
      ]
    },
    "update": {
      "type": "builtin-lifecycle",
      "requiredPaths": [
        "CodingKit/agents/skills/plugins/AiCoding",
        "CodingKit/agents/skills/plugins/AiCoding/.codex-plugin/plugin.json",
        "CodingKit/agents/skills/plugins/AiCoding/BUILDINFO.json",
        "config/codex-kit.json",
        ".agents/plugins/marketplace.json"
      ],
      "supportsJson": true,
      "supportsDryRun": true
    },
    "uninstall": {
      "type": "builtin-lifecycle",
      "requiredPaths": [
        "CodingKit/agents/skills/plugins/AiCoding",
        "config/codex-kit.json",
        ".agents/plugins/marketplace.json"
      ],
      "supportsJson": true,
      "supportsDryRun": true
    },
    "export": {
      "type": "builtin-package",
      "include": [
        "config/codex-kit.json",
        ".agents/plugins/marketplace.json",
        "tools/specialty/*codex-kit.ps1",
        "tools/specialty/lib/CodexKit.psm1",
        "CodingKit/README.md"
      ],
      "exclude": [
        "CodingKit/agents/skills/**"
      ],
      "outputName": "aicoding-platform-${version}.zip"
    }
  },
  "skills": {
    "umbrella": {
      "id": "aicoding-embedded",
      "path": "CodingKit/agents/skills/plugins/AiCoding/skills/aicoding-embedded/SKILL.md",
      "role": "router",
      "description": "Umbrella entry for embedded AiCoding workflows.",
      "tags": [
        "embedded",
        "router"
      ]
    },
    "members": [
      {
        "id": "aicoding-kit-maintenance",
        "path": "CodingKit/agents/skills/plugins/AiCoding/skills/aicoding-kit-maintenance/SKILL.md",
        "role": "subskill",
        "description": "Maintains AiCoding kit lifecycle and package workflows.",
        "tags": [
          "kit",
          "maintenance"
        ]
      }
    ]
  },
  "hooks": {
    "repo": [],
    "agent": [],
    "kit": []
  },
  "commonDependencies": [],
  "export": {
    "include": [
      "config/codex-kit.json",
      ".agents/plugins/marketplace.json",
      "tools/specialty/*codex-kit.ps1",
      "tools/specialty/lib/CodexKit.psm1",
      "CodingKit/README.md"
    ],
    "exclude": [
      "CodingKit/agents/skills/**"
    ],
    "outputName": "aicoding-platform-${version}.zip"
  },
  "state": {
    "root": ".aicoding/state/kits/aicoding-platform",
    "installState": ".aicoding/state/kits/aicoding-platform/install-state.json"
  },
  "trust": {
    "level": "first-party",
    "source": "AiCoding",
    "thirdParty": false,
    "updatePolicy": "manual"
  },
  "profiles": {
    "Smoke": {
      "default": true,
      "maxSeconds": 20
    },
    "Full": {
      "explicit": true
    },
    "Release": {
      "explicit": true,
      "packageRestore": true
    }
  }
}
