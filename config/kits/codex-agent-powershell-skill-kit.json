{
  "schemaVersion": 2,
  "id": "codex-agent-powershell-skill-kit",
  "name": "Codex Agent PowerShell Skill Kit",
  "version": "1.2.1",
  "kind": [
    "plugin-kit",
    "powershell-skill-kit",
    "quality-gate-kit"
  ],
  "mode": "script-adapter",
  "description": "PowerShell 7-first agent guard with AST, safe rewrite, runtime, and PSScriptAnalyzer gates.",
  "paths": {
    "pluginRoot": "dist/codex-agent-powershell-skill-kit/plugins/AiCodingPowerShellSkillKit",
    "pluginManifest": "dist/codex-agent-powershell-skill-kit/plugins/AiCodingPowerShellSkillKit/.codex-plugin/plugin.json",
    "runtimeMirror": ".agents/skills/codex-agent-powershell-skill-kit",
    "stateRoot": ".codex-agent-powershell-skill-kit",
    "marketplace": ".agents/plugins/marketplace.json"
  },
  "commands": {
    "install": {
      "type": "powershell-script",
      "path": "scripts/install-codex-agent-powershell-skill-kit.ps1",
      "args": [
        "-RepoRoot",
        "${repoRoot}"
      ],
      "supportsJson": false,
      "supportsDryRun": true
    },
    "status": {
      "type": "powershell-script",
      "path": "scripts/status-codex-agent-powershell-skill-kit.ps1",
      "args": [
        "-RepoRoot",
        "${repoRoot}"
      ],
      "supportsJson": true
    },
    "verify": {
      "type": "powershell-script",
      "path": "scripts/verify-codex-agent-powershell-skill-kit.ps1",
      "args": [
        "-RepoRoot",
        "${repoRoot}"
      ],
      "supportsJson": true
    },
    "test": {
      "type": "powershell-script",
      "path": "scripts/test-codex-agent-powershell-skill-kit.ps1",
      "args": [
        "-RepoRoot",
        "${repoRoot}"
      ],
      "supportsJson": true
    },
    "uninstall": {
      "type": "powershell-script",
      "path": "scripts/uninstall-codex-agent-powershell-skill-kit.ps1",
      "args": [
        "-RepoRoot",
        "${repoRoot}"
      ],
      "supportsJson": false
    },
    "update": {
      "type": "composed",
      "steps": [
        "install",
        "verify"
      ]
    },
    "export": {
      "type": "builtin-package",
      "include": [
        "dist/codex-agent-powershell-skill-kit/**",
        "config/codex-agent-powershell-skill-kit.json",
        "scripts/install-codex-agent-powershell-skill-kit.ps1",
        "scripts/status-codex-agent-powershell-skill-kit.ps1",
        "scripts/verify-codex-agent-powershell-skill-kit.ps1",
        "scripts/test-codex-agent-powershell-skill-kit.ps1",
        "scripts/uninstall-codex-agent-powershell-skill-kit.ps1"
      ],
      "exclude": [
        "**/__pycache__/**",
        "**/.pytest_cache/**"
      ],
      "outputName": "codex-agent-powershell-skill-kit-${version}.zip"
    }
  },
  "skills": {
    "umbrella": {
      "id": "codex-agent-powershell-skill-kit",
      "path": "dist/codex-agent-powershell-skill-kit/plugins/AiCodingPowerShellSkillKit/skills/codex-agent-powershell-skill-kit/SKILL.md",
      "role": "router",
      "description": "PowerShell 7 AST, safety, and analyzer guard.",
      "tags": [
        "powershell",
        "gate"
      ]
    },
    "members": []
  },
  "hooks": {
    "repo": [],
    "agent": [],
    "kit": []
  },
  "commonDependencies": [],
  "export": {
    "include": [
      "dist/codex-agent-powershell-skill-kit/**",
      "config/codex-agent-powershell-skill-kit.json",
      "scripts/install-codex-agent-powershell-skill-kit.ps1",
      "scripts/status-codex-agent-powershell-skill-kit.ps1",
      "scripts/verify-codex-agent-powershell-skill-kit.ps1",
      "scripts/test-codex-agent-powershell-skill-kit.ps1",
      "scripts/uninstall-codex-agent-powershell-skill-kit.ps1"
    ],
    "exclude": [
      "**/__pycache__/**",
      "**/.pytest_cache/**"
    ],
    "outputName": "codex-agent-powershell-skill-kit-${version}.zip"
  },
  "state": {
    "root": ".aicoding/state/kits/codex-agent-powershell-skill-kit",
    "installState": ".aicoding/state/kits/codex-agent-powershell-skill-kit/install-state.json"
  },
  "trust": {
    "level": "first-party",
    "source": "AiCoding",
    "thirdParty": false,
    "updatePolicy": "manual"
  },
  "profiles": {
    "Smoke": {
      "default": true,
      "maxSeconds": 20
    },
    "Full": {
      "explicit": true
    },
    "Release": {
      "explicit": true,
      "packageRestore": true
    }
  }
}
