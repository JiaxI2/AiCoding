{
  "schemaVersion": 2,
  "id": "agent-patch-kit",
  "name": "Agent Patch Kit",
  "version": "0.2.2",
  "kind": [
    "plugin-kit",
    "python-cli-kit",
    "workflow-kit"
  ],
  "mode": "script-adapter",
  "description": "Safe patch workflow, fixed-string scan/replace, transaction snapshots, and markdown link checks through the apatch CLI.",
  "paths": {
    "pluginRoot": "dist/agent-patch-kit/plugins/AiCodingAgentPatch",
    "pluginManifest": "dist/agent-patch-kit/plugins/AiCodingAgentPatch/.codex-plugin/plugin.json",
    "assetRoot": "dist/agent-patch-kit/plugins/AiCodingAgentPatch/assets",
    "marketplace": ".agents/plugins/marketplace.json",
    "stateRoot": ".agentpatch"
  },
  "commands": {
    "install": {
      "type": "powershell-script",
      "path": "dist/agent-patch-kit/plugins/AiCodingAgentPatch/assets/scripts/install-agent-patch-kit.ps1",
      "args": [
        "-InstallMissing"
      ],
      "supportsJson": false,
      "supportsDryRun": false
    },
    "status": {
      "type": "external-command",
      "executable": "apatch",
      "args": [
        "status"
      ]
    },
    "doctor": {
      "type": "external-command",
      "executable": "apatch",
      "args": [
        "install",
        "doctor"
      ]
    },
    "verify": {
      "type": "composed",
      "steps": [
        "status",
        "doctor"
      ]
    },
    "test": {
      "type": "external-command",
      "executable": "apatch",
      "args": [
        "brief",
        "--format",
        "md"
      ]
    },
    "uninstall": {
      "type": "powershell-script",
      "path": "dist/agent-patch-kit/plugins/AiCodingAgentPatch/assets/scripts/uninstall-agent-patch-kit.ps1",
      "args": [],
      "supportsJson": false
    },
    "update": {
      "type": "composed",
      "steps": [
        "install",
        "verify"
      ]
    },
    "export": {
      "type": "builtin-package",
      "include": [
        "dist/agent-patch-kit/**",
        "config/agent-patch-kit.json"
      ],
      "exclude": [
        "**/__pycache__/**",
        "**/.pytest_cache/**",
        "**/*.pyc",
        "**/.venv/**"
      ],
      "outputName": "agent-patch-kit-${version}.zip"
    }
  },
  "skills": {
    "umbrella": {
      "id": "aicoding-agent-patch-kit",
      "path": "dist/agent-patch-kit/plugins/AiCodingAgentPatch/skills/aicoding-agent-patch-kit/SKILL.md",
      "role": "router",
      "description": "Safe repository patching and link-check workflow.",
      "tags": [
        "patch",
        "docs"
      ]
    },
    "members": []
  },
  "hooks": {
    "repo": [],
    "agent": [],
    "kit": []
  },
  "commonDependencies": [],
  "export": {
    "include": [
      "dist/agent-patch-kit/**",
      "config/agent-patch-kit.json"
    ],
    "exclude": [
      "**/__pycache__/**",
      "**/.pytest_cache/**",
      "**/*.pyc",
      "**/.venv/**"
    ],
    "outputName": "agent-patch-kit-${version}.zip"
  },
  "state": {
    "root": ".aicoding/state/kits/agent-patch-kit",
    "installState": ".aicoding/state/kits/agent-patch-kit/install-state.json"
  },
  "trust": {
    "level": "first-party",
    "source": "AiCoding",
    "thirdParty": false,
    "updatePolicy": "manual"
  },
  "profiles": {
    "Smoke": {
      "default": true,
      "maxSeconds": 20
    },
    "Full": {
      "explicit": true
    },
    "Release": {
      "explicit": true,
      "packageRestore": true
    }
  }
}
