{
  "schemaVersion": 2,
  "id": "c-style-format-kit",
  "name": "C Style Format Kit",
  "version": "0.2.0",
  "kind": [
    "quality-gate-kit",
    "style-kit",
    "c-format-kit",
    "go-fast-path-kit",
    "comment-template-kit"
  ],
  "mode": "script-adapter",
  "description": "Go-native changed-file C/H formatting, format checks, and repository-native embedded C comment templates.",
  "paths": {
    "styleConfig": ".clang-format",
    "goPackage": "internal/cstyle",
    "commentTemplates": "config/cstyle/comment-templates.json",
    "skillOverlay": "config/skills/c99-standard-c-overlay.md"
  },
  "commands": {
    "status": { "type": "external-command", "executable": "bin/aicoding.exe", "args": ["cstyle", "status", "--json"], "supportsJson": true },
    "doctor": { "type": "external-command", "executable": "bin/aicoding.exe", "args": ["cstyle", "templates", "--json"], "supportsJson": true },
    "verify": { "type": "external-command", "executable": "bin/aicoding.exe", "args": ["cstyle", "check", "--scope", "changed", "--json"], "supportsJson": true },
    "test": { "type": "external-command", "executable": "go", "args": ["test", "./internal/cstyle"], "supportsJson": false }
  },
  "skills": { "members": [] },
  "hooks": { "repo": [], "agent": [], "kit": [] },
  "commonDependencies": [
    { "id": "clang-format", "path": "PATH:clang-format", "version": "system", "usage": "deterministic C/H style formatter" }
  ],
  "export": {
    "include": [
      ".clang-format",
      "internal/cstyle/**",
      "config/cstyle/comment-templates.json",
      "config/skills/c99-standard-c-overlay.md",
      "config/kits/c-style-format-kit.json",
      "docs/C_STYLE_FORMAT_KIT.md",
      "tests/style-samples/**"
    ],
    "exclude": ["**/__pycache__/**", "**/.pytest_cache/**"],
    "outputName": "c-style-format-kit-${version}.zip"
  },
  "state": { "root": ".aicoding/state/kits/c-style-format-kit", "installState": ".aicoding/state/kits/c-style-format-kit/install-state.json" },
  "trust": { "level": "first-party", "source": "AiCoding", "thirdParty": false, "updatePolicy": "manual" },
  "profiles": { "Smoke": { "default": true, "maxSeconds": 10 }, "Full": { "explicit": true }, "Release": { "explicit": true, "packageRestore": false } }
}