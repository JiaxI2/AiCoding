{
  "schemaVersion": 2,
  "id": "ai-debug-repair-kit",
  "name": "AI Debug Repair Kit",
  "version": "0.4.1",
  "kind": [
    "plugin-kit",
    "python-cli-kit",
    "debug-kit",
    "repair-kit"
  ],
  "mode": "external-cli",
  "description": "Bounded build/test repair loop and non-invasive TI DSS debug workflows through the airepair CLI.",
  "paths": {
    "pluginRoot": "dist/ai-debug-repair-kit/plugins/AiCodingAIDebugRepairKit",
    "pluginManifest": "dist/ai-debug-repair-kit/plugins/AiCodingAIDebugRepairKit/.codex-plugin/plugin.json",
    "assetRoot": "dist/ai-debug-repair-kit/plugins/AiCodingAIDebugRepairKit/assets/ai-debug-repair-kit",
    "stateRoot": ".aicoding/state/kits/ai-debug-repair-kit",
    "legacyStateRoot": ".ai-debug-repair",
    "marketplace": ".agents/plugins/marketplace.json"
  },
  "commands": {
    "install": {
      "type": "builtin-lifecycle",
      "requiredPaths": [
        "dist/ai-debug-repair-kit/plugins/AiCodingAIDebugRepairKit",
        "dist/ai-debug-repair-kit/plugins/AiCodingAIDebugRepairKit/assets/ai-debug-repair-kit",
        ".agents/plugins/marketplace.json"
      ],
      "supportsJson": true,
      "supportsDryRun": true
    },
    "status": {
      "type": "specialty-pwsh",
      "path": "scripts/status-ai-debug-repair-kit.ps1",
      "args": [
        "-RepoRoot",
        "${repoRoot}"
      ],
      "supportsJson": true
    },
    "verify": {
      "type": "specialty-pwsh",
      "path": "scripts/verify-ai-debug-repair-kit.ps1",
      "args": [
        "-RepoRoot",
        "${repoRoot}"
      ],
      "supportsJson": true
    },
    "test": {
      "type": "specialty-pwsh",
      "path": "scripts/test-ai-debug-repair-kit.ps1",
      "args": [
        "-RepoRoot",
        "${repoRoot}"
      ],
      "supportsJson": true
    },
    "uninstall": {
      "type": "builtin-lifecycle",
      "requiredPaths": [
        "dist/ai-debug-repair-kit/plugins/AiCodingAIDebugRepairKit",
        "dist/ai-debug-repair-kit/plugins/AiCodingAIDebugRepairKit/assets/ai-debug-repair-kit",
        ".agents/plugins/marketplace.json"
      ],
      "supportsJson": true,
      "supportsDryRun": true
    },
    "update": {
      "type": "builtin-lifecycle",
      "requiredPaths": [
        "dist/ai-debug-repair-kit/plugins/AiCodingAIDebugRepairKit",
        "dist/ai-debug-repair-kit/plugins/AiCodingAIDebugRepairKit/assets/ai-debug-repair-kit",
        ".agents/plugins/marketplace.json"
      ],
      "supportsJson": true,
      "supportsDryRun": true
    },
    "export": {
      "type": "builtin-package",
      "include": [
        "dist/ai-debug-repair-kit/**",
        "scripts/status-ai-debug-repair-kit.ps1",
        "scripts/verify-ai-debug-repair-kit.ps1",
        "scripts/test-ai-debug-repair-kit.ps1"
      ],
      "exclude": [
        "**/__pycache__/**",
        "**/.pytest_cache/**",
        "**/*.pyc",
        "**/.venv/**"
      ],
      "outputName": "ai-debug-repair-kit-${version}.zip"
    }
  },
  "skills": {
    "umbrella": {
      "id": "ai-debug-repair-loop",
      "path": "dist/ai-debug-repair-kit/plugins/AiCodingAIDebugRepairKit/skills/ai-debug-repair-loop/SKILL.md",
      "role": "router",
      "description": "Bounded debug and repair loop orchestration.",
      "tags": [
        "debug",
        "repair"
      ]
    },
    "members": [
      {
        "id": "ai-debug-operations",
        "path": "dist/ai-debug-repair-kit/plugins/AiCodingAIDebugRepairKit/skills/ai-debug-operations/SKILL.md",
        "role": "subskill",
        "description": "Non-invasive debug operation workflows.",
        "tags": [
          "debug",
          "operations"
        ]
      }
    ]
  },
  "hooks": {
    "repo": [],
    "agent": [],
    "kit": []
  },
  "commonDependencies": [],
  "export": {
    "include": [
      "dist/ai-debug-repair-kit/**",
      "scripts/status-ai-debug-repair-kit.ps1",
      "scripts/verify-ai-debug-repair-kit.ps1",
      "scripts/test-ai-debug-repair-kit.ps1"
    ],
    "exclude": [
      "**/__pycache__/**",
      "**/.pytest_cache/**",
      "**/*.pyc",
      "**/.venv/**"
    ],
    "outputName": "ai-debug-repair-kit-${version}.zip"
  },
  "state": {
    "root": ".aicoding/state/kits/ai-debug-repair-kit",
    "installState": ".aicoding/state/kits/ai-debug-repair-kit/install-state.json"
  },
  "trust": {
    "level": "first-party",
    "source": "AiCoding",
    "thirdParty": false,
    "updatePolicy": "manual"
  },
  "profiles": {
    "Smoke": {
      "default": true,
      "maxSeconds": 20
    },
    "Full": {
      "explicit": true
    },
    "Release": {
      "explicit": true,
      "packageRestore": true
    }
  }
}
