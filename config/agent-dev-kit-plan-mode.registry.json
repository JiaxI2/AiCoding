{
  "schemaVersion": 1,
  "id": "aicoding-agent-dev-kit-plan-mode",
  "owner": "aicoding-agent-dev-kit",
  "description": "中文优先的 AiCoding Agent Dev Kit 计划模式（Plan Mode）工作流 overlay，用于适配 Codex Plan Mode、Spec Kit 阶段和显式 workflow 习惯。",
  "phases": [
    {
      "id": "clarify",
      "artifact": "docs/spec/<id>/OPTIONS.md",
      "requiredWhen": "requirement is fuzzy"
    },
    {
      "id": "specify",
      "artifact": "docs/spec/<id>/PLAN.md",
      "requiredWhen": "non-trivial work"
    },
    {
      "id": "plan",
      "artifact": "docs/spec/<id>/PLAN.md",
      "requiredWhen": "implementation changes"
    },
    {
      "id": "decision",
      "artifact": "docs/spec/<id>/DECISION.md",
      "requiredWhen": "multiple architecture options exist"
    },
    {
      "id": "tasks",
      "artifact": "docs/spec/<id>/TASKS.md",
      "requiredWhen": "implementation changes"
    },
    {
      "id": "traceability",
      "artifact": "docs/spec/<id>/PLAN.md",
      "requiredWhen": "implementation changes"
    },
    {
      "id": "verify",
      "artifact": "verification output",
      "requiredWhen": "handoff"
    }
  ],
  "stopFiles": [
    "docs/spec/<id>/PLAN.md#status=needs-decision"
  ],
  "acceptedDecisionArtifacts": [
    "docs/spec/<id>/DECISION.md",
    ".aicoding/memory/DECISIONS.md",
    "docs/decisions",
    "docs/adr"
  ],
  "architectureSensitivePaths": [
    "config/kits/",
    "config/*.registry.json",
    "config/schemas/",
    "tools/specialty/",
    "tools/specialty/lib/",
    "tools/specialty/hooks/",
    ".agents/skills/",
    "CodingKit/modules/",
    "docs/AGENT_",
    "Taskfile",
    ".github/workflows/"
  ],
  "requiredMarkers": {
    "selectedDecision": [
      "Decision Status: Selected",
      "Status: Accepted",
      "Selected option:",
      "Human selection:",
      "User selected:",
      "用户选择：",
      "状态：已选择"
    ],
    "approvedPlan": [
      "Plan Status: Approved",
      "Implementation Plan: Approved",
      "Status: Accepted",
      "计划状态：已批准"
    ]
  },
  "hookModules": [
    "plan-mode-gate",
    "spec-artifact-gate"
  ],
  "languagePolicy": {
    "defaultUserLanguage": "zh-CN",
    "userFacingOutput": "zh-CN-first",
    "permissionSummary": "zh-CN-first",
    "toolExplanation": "zh-CN-first",
    "hookMessage": "zh-CN-first",
    "scriptMessage": "zh-CN-first",
    "allowEnglishTerms": true,
    "preserveMachineKeys": true,
    "examples": {
      "permissionReadRegistry": "读取 Plan Mode registry，用于验证前检查。",
      "permissionRunVerify": "运行 Plan Mode 验证脚本，确认规格、计划、任务和决策记录完整。",
      "permissionReadSpec": "读取规格文档，用于判断是否需要用户选择技术路线。",
      "decisionBlocked": "检测到用户尚未选择技术路线，禁止继续实现。",
      "gatePassed": "Plan Mode 门禁验证通过。"
    }
  }
}
