{
  "version": 1,
  "description": "AiCoding DocSync Plus semantic drift policy.",
  "thresholds": {
    "preCommitWarn": 10,
    "preCommitBlock": 30,
    "allBlock": 25,
    "ciBlock": 10,
    "releaseBlock": 0
  },
  "weights": {
    "apiDrift": 35,
    "behaviorDrift": 25,
    "policyDrift": 20,
    "commandDrift": 10,
    "linkDrift": 10
  },
  "publicSurfaces": [
    "cmd/**/*.go:command",
    "internal/cli/**/*.go:command",
    "internal/testengine/**/*.go:profile",
    "Taskfile.yml:tasks",
    "tools/specialty/**/*.ps1:param",
    "tools/specialty/**/*.ps1:function",
    "config/docs-sync.policy.json:rules",
    "config/docs-sync.semantic.json:thresholds",
    ".githooks/**",
    ".github/workflows/**"
  ],
  "docTargets": {
    "internal/cli/cli.go": [
      "README.md",
      "README_CN.md",
      "README_EN.md",
      "docs/COMMANDS.md",
      "docs/ARCHITECTURE_OVERVIEW.md",
      "CHANGELOG.md"
    ],
    "internal/cli/contract.go": [
      "docs/COMMANDS.md",
      "docs/operations/testing/REPORT_SCHEMA.md",
      "CHANGELOG.md"
    ],
    "internal/cli/product.go": [
      "docs/COMMANDS.md",
      "docs/ARCHITECTURE_OVERVIEW.md",
      "docs/operations/testing/REPORT_SCHEMA.md",
      "CHANGELOG.md"
    ],
    "internal/testengine/engine.go": [
      "docs/COMMANDS.md",
      "docs/operations/testing/GLOBAL_TEST_PLAN.md",
      "docs/operations/testing/GLOBAL_TEST_CASES.md",
      "CHANGELOG.md"
    ],
    "Taskfile.yml": [
      "docs/COMMANDS.md",
      "README.md",
      "README_CN.md",
      "README_EN.md",
      "CHANGELOG.md"
    ],
    "config/schemas/cli-report.schema.json": [
      "docs/operations/testing/REPORT_SCHEMA.md",
      "docs/COMMANDS.md",
      "CHANGELOG.md"
    ],
    "internal/docsync/check.go": [
      "README.md",
      "docs/operations/MAINTENANCE_METHOD.md",
      "docs/architecture/DOC_SYNC_PLUS_SPEC.md",
      "CHANGELOG.md"
    ],
    "config/docs-sync.policy.json": [
      "docs/architecture/DOC_SYNC_PLUS_SPEC.md",
      "docs/operations/MAINTENANCE_METHOD.md",
      "README.md",
      "CHANGELOG.md"
    ],
    ".githooks/pre-commit": [
      "docs/operations/MAINTENANCE_METHOD.md",
      "AGENTS.md",
      "CHANGELOG.md"
    ],
    ".github/workflows/aicoding-ci.yml": [
      "docs/operations/MAINTENANCE_METHOD.md",
      "AGENTS.md",
      "CHANGELOG.md"
    ]
  },
  "noDocMarker": {
    "marker": "DOCSYNC-NO-DOC-CHANGE",
    "minimumReasonLength": 20,
    "forbiddenReasons": [
      "skip",
      "none",
      "no",
      "n/a",
      "no change"
    ]
  }
}
