{
  "name": "AiCoding",
  "version": "0.1.0",
  "codingKitRoot": "./CodingKit",
  "agents": {
    "skillsSubmodule": "./CodingKit/agents/skills",
    "pluginPath": "./CodingKit/agents/skills/plugins/AiCoding",
    "marketplacePath": "./.agents/plugins/marketplace.json"
  },
  "assets": {
    "examples": "./CodingKit/examples",
    "modules": "./CodingKit/modules",
    "platforms": "./CodingKit/platforms",
    "tests": "./CodingKit/tests",
    "tools": "./CodingKit/tools"
  },
  "rules": {
    "buildPluginInSubmodule": false,
    "pluginInstallUsesMarketplace": true,
    "hooksAreAuxiliaryConstraints": true
  },
  "skillRuntime": {
    "canonicalUserRoot": "%USERPROFILE%\\.agents\\skills",
    "legacyUserRoot": "%USERPROFILE%\\.codex\\skills",
    "sourceRepositoryEnv": "AICODING_SKILL_SOURCE_REPO",
    "defaultSourceRepository": "../Codex-Skills",
    "sourceRepositoryMustNotBeUnderSkillRoot": true,
    "rejectDuplicateNames": true,
    "rejectGeneratedSkillLinks": true,
    "rejectWholeRepositoryLinks": true
  },
  "profiles": {
    "runtime": {
      "pluginEnabled": true,
      "sourceSkillLinks": [],
      "standaloneSkills": []
    },
    "skill-development": {
      "pluginEnabled": false,
      "allowSelectedSourceSkillLinks": true,
      "maxSelectedSourceSkills": 1
    },
    "full": {
      "pluginEnabled": true,
      "sourceSkillLinks": [],
      "standaloneSkills": [
        "algorithmic-art",
        "anthropic-docx",
        "anthropic-pdf",
        "anthropic-pptx",
        "anthropic-xlsx",
        "brand-guidelines",
        "canvas-design",
        "claude-api",
        "codex-documents-anthropic-docx",
        "defuddle",
        "doc-coauthoring",
        "drawio",
        "frontend-design",
        "internal-comms",
        "json-canvas",
        "karpathy-guidelines",
        "mcp-builder",
        "obsidian-bases",
        "obsidian-cli",
        "obsidian-markdown",
        "slack-gif-creator",
        "theme-factory",
        "web-artifacts-builder",
        "webapp-testing"
      ]
    }
  },
  "standaloneSkillRegistry": {
    "sourceRepositoryEnv": "AICODING_SKILL_SOURCE_REPO",
    "sourceRepository": "../Codex-Skills",
    "defaultSourceRepository": "../Codex-Skills",
    "defaultInstallRoot": "%USERPROFILE%\\.agents\\skills",
    "supportedInstallRoots": [
      "agents",
      "codex"
    ],
    "linkMode": "junction",
    "installByProfile": true,
    "skills": [
      "algorithmic-art",
      "anthropic-docx",
      "anthropic-pdf",
      "anthropic-pptx",
      "anthropic-xlsx",
      "brand-guidelines",
      "canvas-design",
      "claude-api",
      "codex-documents-anthropic-docx",
      "defuddle",
      "doc-coauthoring",
      "drawio",
      "frontend-design",
      "internal-comms",
      "json-canvas",
      "karpathy-guidelines",
      "mcp-builder",
      "obsidian-bases",
      "obsidian-cli",
      "obsidian-markdown",
      "slack-gif-creator",
      "theme-factory",
      "web-artifacts-builder",
      "webapp-testing"
    ]
  }
}
