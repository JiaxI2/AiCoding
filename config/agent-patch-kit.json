{
  "schema": "agent-patch-kit.config.v2",
  "default_globs": [
    "*.md",
    "*.txt",
    "*.c",
    "*.h",
    "*.cpp",
    "*.hpp",
    "*.py",
    "*.ps1",
    "*.yml",
    "*.yaml",
    "*.json",
    "*.toml"
  ],
  "exclude_dirs": [
    ".git",
    ".agentpatch",
    "node_modules",
    "dist",
    "build",
    "coverage",
    ".venv",
    "__pycache__"
  ],
  "transactions": {
    "auto_begin_for_apply": true,
    "root": ".agentpatch/transactions",
    "keep": 30
  },
  "links": {
    "mode": "offline",
    "include_fragments": "full",
    "inputs": [
      "**/*.md"
    ],
    "config": "lychee.toml"
  },
  "verify": {
    "run_git_diff_check": true,
    "task_verify": false,
    "markdown_links": false
  }
}
