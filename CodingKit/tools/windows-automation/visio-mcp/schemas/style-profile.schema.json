{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://visio-mcp.local/schemas/style-profile.schema.json",
  "title": "Visio Style Profile Registry",
  "type": "object",
  "required": ["schemaVersion", "defaultProfile", "profiles"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {"const": 1},
    "defaultProfile": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9._-]+$"
    },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"$ref": "#/$defs/profile"}
    }
  },
  "$defs": {
    "font": {
      "type": "object",
      "required": ["ordinaryFamily"],
      "additionalProperties": false,
      "properties": {
        "ordinaryFamily": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "asianFamily": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "mathFamily": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        }
      }
    },
    "text": {
      "type": "object",
      "required": ["fontSizePt", "safeRatio"],
      "additionalProperties": false,
      "properties": {
        "fontSizePt": {
          "type": "number",
          "minimum": 6,
          "maximum": 36
        },
        "safeRatio": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 0.9
        }
      }
    },
    "line": {
      "type": "object",
      "required": ["weightPt", "cornerRadiusIn"],
      "additionalProperties": false,
      "properties": {
        "weightPt": {
          "type": "number",
          "minimum": 0.25,
          "maximum": 4
        },
        "cornerRadiusIn": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "profile": {
      "type": "object",
      "required": ["font", "text", "line"],
      "additionalProperties": false,
      "properties": {
        "font": {"$ref": "#/$defs/font"},
        "text": {"$ref": "#/$defs/text"},
        "line": {"$ref": "#/$defs/line"}
      }
    }
  }
}
