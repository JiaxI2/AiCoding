{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/c-userstyle/huawei-c-rule-catalog.schema.json",
  "title": "Huawei C Rule Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schema", "version", "source", "summary", "nonClauseSections", "clauses"],
  "properties": {
    "$schema": {"type": "string", "minLength": 1},
    "schema": {"const": "huawei-c-rule-catalog"},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "pdf", "markdown", "sha256", "pages", "chapters"],
      "properties": {
        "title": {"type": "string", "minLength": 1},
        "pdf": {"type": "string", "pattern": "\\.pdf$"},
        "markdown": {"type": "string", "pattern": "\\.md$"},
        "sha256": {"type": "string", "pattern": "^[A-F0-9]{64}$"},
        "pages": {"const": 61},
        "chapters": {
          "type": "object",
          "additionalProperties": false,
          "required": ["first", "last", "clauseChapters"],
          "properties": {
            "first": {"const": 0},
            "last": {"const": 16},
            "clauseChapters": {
              "type": "array",
              "prefixItems": [{"const": 1}, {"const": 15}],
              "items": false,
              "minItems": 2,
              "maxItems": 2
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expectedClauses", "actualClauses", "kindCounts", "primaryVerificationCounts", "unclassifiedClauses"],
      "properties": {
        "expectedClauses": {"const": 139},
        "actualClauses": {"const": 139},
        "kindCounts": {"type": "object"},
        "primaryVerificationCounts": {"type": "object"},
        "unclassifiedClauses": {"const": 0}
      }
    },
    "nonClauseSections": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["section", "primaryVerification", "evidence", "status"],
        "properties": {
          "section": {"type": "string", "minLength": 1},
          "primaryVerification": {"enum": ["demo", "lint", "compile", "test", "manual"]},
          "evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "status": {"const": "covered"}
        }
      }
    },
    "clauses": {
      "type": "array",
      "minItems": 139,
      "maxItems": 139,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "chapter", "chapterTitle", "kind", "number", "title", "sourceLine", "primaryVerification", "verificationMethods", "evidence", "rationale", "status"],
        "properties": {
          "id": {"type": "string", "pattern": "^HW-C99-(0[1-9]|1[0-5])-[PRS]-[0-9]{2}$"},
          "chapter": {"type": "integer", "minimum": 1, "maximum": 15},
          "chapterTitle": {"type": "string", "minLength": 1},
          "kind": {"enum": ["原则", "规则", "建议"]},
          "number": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+$"},
          "title": {"type": "string", "minLength": 1},
          "sourceLine": {"type": "integer", "minimum": 1},
          "primaryVerification": {"enum": ["demo", "lint", "compile", "test", "manual"]},
          "verificationMethods": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {"enum": ["demo", "lint", "compile", "test", "manual"]}
          },
          "evidence": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "rationale": {"type": "string", "minLength": 1},
          "status": {"const": "covered"}
        }
      }
    }
  }
}
