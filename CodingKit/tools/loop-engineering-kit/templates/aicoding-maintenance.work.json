{
  "schemaVersion": 1,
  "id": "example-aicoding-maintenance",
  "domain": "repository-maintenance",
  "control": {
    "mode": "goal",
    "trigger": {"type": "manual-or-ci-failure"},
    "stoppingRule": {"success": "required-repository-gates-pass", "failure": ["budget-exhausted", "needs-human", "input-drift"]}
  },
  "goal": "Restore AiCoding repository health with the minimum sufficient change.",
  "acceptance": [
    "governance dependencies passes",
    "governance layout passes",
    "verify Smoke passes",
    "test Full passes when risk requires it"
  ],
  "policy": {
    "workspace": "worktree",
    "writeScope": {"allow": ["cmd/**", "internal/**", "config/**", "docs/**", ".github/**", ".githooks/**"], "deny": ["CodingKit/agents/skills/**"]},
    "verification": {"profile": "aicoding-maintenance"},
    "budget": {"maxAttempts": 3, "maxElapsedSeconds": 5400},
    "humanCheckpoints": ["architecture-unfreeze", "submodule-pin-change", "merge", "release"]
  }
}
